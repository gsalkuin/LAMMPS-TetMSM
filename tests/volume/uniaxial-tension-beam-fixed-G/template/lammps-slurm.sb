#!/usr/bin/env bash

#SBATCH --job-name=nu-NUVAL-beam-N8
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=8
#SBATCH --cpus-per-task=1
#SBATCH --output=%x.%N.%j.out
#SBATCH --partition=compute_zone2

module reset
module load gnu12/12.3.0
module load openmpi4/4.1.6

rm -rf nu-NUVAL-dump && mkdir nu-NUVAL-dump 
mpirun -n "${SLURM_NTASKS_PER_NODE}" /home/gsalkuin/LAMMPS-source/lammps-10Dec2025/lmp_tetmsm_v2 -in in.deform
