##############################################################
# Uniaxial tension -- beam
# Tetrahedral MSM with bond_style/improper_style tetmsm
#
# Beam: 0.4 x 0.4 x 2.4 (aspect ratio 1:1:6)
# Bottom face: fully clamped (setforce 0 0 0)
# Top face:    displaced upward, free in x,y
# Lateral faces: completely free
#
# E  = sigma_z / ez  (from reaction force, global)
# nu = least-squares slope of u_x vs x0 over mid-section
#
##############################################################

# ---- Material parameters ----
variable        NU     equal NUVAL      # Poisson's ratio
variable        G      equal 4000.0
variable        E      equal "2 * v_G * (1 + v_NU)"

variable        CUTOFF equal 0.2

##############################################################

units           si
dimension       3
boundary        s s s
processors      * * *

atom_style      hybrid full sphere

read_data       beam-N8.lam nocoeff

neighbor        $(v_CUTOFF*0.05) bin

pair_style      zero ${CUTOFF}
pair_coeff      * * ${CUTOFF}

# ---- tetmsm styles ----
bond_style      tetmsm
improper_style  tetmsm

bond_coeff      1
improper_coeff  1 ${G} ${NU}

##############################################################
# GROUPS (beam in [0,0.4] x [0,0.4] x [0,2.4])
##############################################################

region          rbot block INF INF INF INF INF 0.01 units box
region          rtop block INF INF INF INF 2.39 INF units box
region          rmid block INF INF INF INF 0.8 1.6 units box

group           gbot region rbot
group           gtop region rtop
group           gmid region rmid

##############################################################
# BOUNDARY CONDITIONS
##############################################################

fix             fbc_bot gbot setforce 0 0 0
fix             fbc_top gtop setforce NULL NULL 0

##############################################################
# INITIAL MINIMIZATION
##############################################################

min_style       cg
min_modify      dmax 0.01
minimize        1e-10 1e-10 10000 100000

##############################################################
# REFERENCE GEOMETRY
##############################################################

# Store reference positions (after initial minimize)
fix             fref all store/state 0 x y z

# Global (for ez and E)
compute         czmax all reduce max z
compute         czmin all reduce min z

variable        dz equal c_czmax-c_czmin

# Cross-sectional area (max/min is fine for area — global quantity)
compute         mxmax gmid reduce max x
compute         mxmin gmid reduce min x
compute         mymax gmid reduce max y
compute         mymin gmid reduce min y

variable        dxm equal c_mxmax-c_mxmin
variable        dym equal c_mymax-c_mymin
variable        A0  equal "v_dxm * v_dym"

# ---- Least-squares nu measurement ----
# eps_x = cov(u_x, x0) / var(x0)  where u_x = x - x0
# eps_y = cov(u_y, y0) / var(y0)

# Per-atom quantities
variable        ux atom x-f_fref[1]
variable        uy atom y-f_fref[2]
variable        ux_x0 atom v_ux*f_fref[1]
variable        uy_y0 atom v_uy*f_fref[2]
variable        x0sq atom f_fref[1]*f_fref[1]
variable        y0sq atom f_fref[2]*f_fref[2]

# Reductions over mid-section
compute         avg_ux gmid reduce ave v_ux
compute         avg_uy gmid reduce ave v_uy
compute         avg_uxx0 gmid reduce ave v_ux_x0
compute         avg_uyy0 gmid reduce ave v_uy_y0
compute         avg_x0sq gmid reduce ave v_x0sq
compute         avg_y0sq gmid reduce ave v_y0sq
compute         avg_x0 gmid reduce ave f_fref[1]
compute         avg_y0 gmid reduce ave f_fref[2]

run             0

# Reference variances (constants, evaluated once)
variable        var_x0 equal $(c_avg_x0sq - c_avg_x0*c_avg_x0)
variable        var_y0 equal $(c_avg_y0sq - c_avg_y0*c_avg_y0)

variable        Lz0  equal ${dz}

print           "Initial Length: ${Lz0}"
print           "Initial area A0: ${A0}"
print           "var(x0) = ${var_x0}, var(y0) = ${var_y0}"

##############################################################
# DEFORMATION SETUP
##############################################################

reset_timestep  0

variable        emax  equal 0.05
variable        Nstep equal 100
variable        de    equal "v_emax / v_Nstep"

# ---- Strains ----
variable        ez  equal "(v_dz - v_Lz0) / v_Lz0"

# Lateral strains from least-squares slope
variable        cov_x equal "c_avg_uxx0 - c_avg_ux * c_avg_x0"
variable        cov_y equal "c_avg_uyy0 - c_avg_uy * c_avg_y0"
variable        exm equal "v_cov_x / v_var_x0"
variable        eym equal "v_cov_y / v_var_y0"

variable        nux equal "-v_exm/v_ez"
variable        nuy equal "-v_eym/v_ez"

# ---- Stress from reaction force ----
variable        fz_bot  equal f_fbc_bot[3]
variable        sigma_z equal "f_fbc_bot[3] / v_A0"

# ---- Output header ----
print           "# ez sigma_z exm eym nux nuy fz_bot" &
                file tens-beam-N8-nu-${NU}.txt screen no

# ---- Thermo ----
thermo          100
thermo_style    custom step pe fnorm fmax press

##############################################################
# TENSION LOOP
##############################################################

variable        k loop ${Nstep}
label           LOOPSTART

    variable    dztop equal "v_de * v_Lz0"
    displace_atoms all ramp z 0.0 ${dztop} z 0.0 2.4 units box

    minimize    1e-10 1e-10 10000 100000

    print       "${ez} ${sigma_z} ${exm} ${eym} ${nux} ${nuy} ${fz_bot}" &
                append tens-beam-N8-nu-${NU}.txt screen no

    write_dump  all custom nu-${NU}-dump/step-${k}.dump &
                id type x y z fx fy fz &
                modify sort id

next            k
jump            SELF LOOPSTART

print           "Done. ez=${ez}, sigma_z=${sigma_z}, nux=${nux}, nuy=${nuy}"
